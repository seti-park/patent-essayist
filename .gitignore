# Runtime handoff artifacts are regenerated each pipeline run; keep the
# directory structure (.gitkeep) but don't track generated stage outputs.
handoff/**
!handoff/
!handoff/*/
!handoff/**/.gitkeep

# Pipeline inputs are provided per run; keep the dirs, ignore the payloads.
input/**
!input/
!input/figures/
!input/**/.gitkeep

# Per-run archives under runs/ ARE tracked (committed after each essay run): in the
# ephemeral Claude Code container they are the evidence chain behind the meta-loop's
# findings ledger and improvement proposals. (meta/ is tracked for the same reason.)

# Python
__pycache__/
*.pyc
