# Runtime handoff artifacts are regenerated each pipeline run; keep the
# directory structure (.gitkeep) but don't track generated stage outputs.
handoff/**
!handoff/
!handoff/*/
!handoff/**/.gitkeep

# Pipeline inputs are provided per run; keep the dirs, ignore the payloads.
# (figures-work/ — Phase 0 staging — stays ignored by input/**.)
input/**
!input/
!input/figures/
!input/figures-raw/
!input/**/.gitkeep

# Per-run archives are generated each pipeline run; keep the dir, ignore payloads.
# (meta/ — the findings ledger, attribution table, fixtures, proposals — IS tracked:
# it is the system's persistent memory, not a per-run artifact.)
runs/**
!runs/
!runs/.gitkeep

# Python
__pycache__/
*.pyc
